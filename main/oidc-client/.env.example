# OIDC Configuration
# このファイルをコピーして .env ファイルを作成してください（Git管理対象外）
# コピー: cp .env.example .env

# Keycloak Realm URL
VITE_OIDC_AUTHORITY=http://localhost:8082/realms/myrealm

# Keycloak Client ID
VITE_OIDC_CLIENT_ID=oidc-client

# Keycloak Client Secret（Keycloak管理コンソールで取得）
# Clients → oidc-client → Credentials → Client Secret
VITE_OIDC_CLIENT_SECRET=your-client-secret-here

# OIDC Callback URL
VITE_OIDC_REDIRECT_URI=http://localhost:8081/callback
